  m_TableData:
  - m_Id: 534859776
    m_Localized: "\uC0C1 \uBBF8\uAC94 \uC120\uBC15\uC758 \uBCF4\uD5D8\uC744 \uACC4\uC57D\uD558\uB7EC
      \uC654\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 572608512
    m_Localized: "\uC548\uC804\uD55C \uD56D\uD574 \uC77C\uC815\uC785\uB2C8\uB2E4.
      \uCD5C\uB300\uD55C \uBE60\uB978 \uC2EC\uC0AC \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 572608513
    m_Localized: "\uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC2E0\uB8B0\uC5D0 \uBCF4\uB2F5\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 572608514
    m_Localized: "\uB124 \uBB50\uB77C\uACE0\uC694? \uBB38\uC81C\uAC00 \uC5C6\uB294\uB370
      \uC65C \uBCF4\uD5D8\uB8CC\uB97C \uD560\uC99D\uD569\uB2C8\uAE4C?!"
    m_Metadata:
      m_Items: []
  - m_Id: 576802816
    m_Localized: "\uB410\uC5B4\uC694! \uC774\uB7F0 \uACF3\uC774\uB791 \uC548 \uD569\uB2C8\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 576802823
    m_Localized: "\uC870\uAC74\uC744 \uD655\uC778\uD558\uACE0 \uC2B9\uC778\uD574
      \uC8FC\uC2E0\uB2E4\uBA74 \uB0A9\uB4DD\uD558\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 576802817
    m_Localized: "\uBD84\uBA85 \uC548\uC804\uD55C \uACC4\uC57D\uC778\uB370\u2026
      \uACA8\uC6B0 \uC0AC\uC778 \uD558\uB098 \uB54C\uBB38\uC5D0 \uCD9C\uD56D\uB97C
      \uBABB\uD560 \uC218\uB3C4 \uC788\uB2E4\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 576802818
    m_Localized: "\uC2B9\uC778\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 576802819
    m_Localized: "\uC870\uAC74\uBD80\uB85C \uBC1B\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 576802820
    m_Localized: "\uAC70\uC808\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 576802821
    m_Localized: "\uAC80\uC815 \uD310\uC815\uC774 \uBD88\uD569\uACA9\uC73C\uB85C
      \uC801\uD600 \uC788\uB2E4\uBA74 \uC2EC\uC0AC\uC5D0 \uBC18\uC601\uD574 \uC8FC\uC2ED\uC2DC\uC624."
    m_Metadata:
      m_Items: []
  - m_Id: 576802822
    m_Localized: "\uAE30\uC0C1 \uC608\uCE21\uC774 \uC88B\uC9C0 \uC54A\uB2E4\uBA74
      \uC870\uAC74\uBD80 \uD310\uB2E8\uC774 \uD544\uC694\uD560 \uC218 \uC788\uACA0\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
