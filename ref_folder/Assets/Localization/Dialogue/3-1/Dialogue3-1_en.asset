  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue3-1_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 9a250fb4baa3778428997edcd2ccc386, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 534859776
    m_Localized: Good day. I am here regarding {insurance.ship.name}, owned by {insurance.ship.owner.name}.
    m_Metadata:
      m_Items: []
  - m_Id: 572608514
    m_Localized: I believe all required documents have been submitted.
    m_Metadata:
      m_Items: []
  - m_Id: 576802816
    m_Localized: Your finding is correct.
    m_Metadata:
      m_Items: []
  - m_Id: 576802817
    m_Localized: I would like you to check that part again.
    m_Metadata:
      m_Items: []
  - m_Id: 576802818
    m_Localized: The ship registration certificate will be submitted shortly.
    m_Metadata:
      m_Items: []
  - m_Id: 576802819
    m_Localized: The hull inspection certificate has not arrived from the yard yet.
    m_Metadata:
      m_Items: []
  - m_Id: 576802820
    m_Localized: The route declaration will be submitted after port confirmation.
    m_Metadata:
      m_Items: []
  - m_Id: 576802821
    m_Localized: If the inspection result is marked failed, please reflect that in
      the review.
    m_Metadata:
      m_Items: []
  - m_Id: 576802822
    m_Localized: If the forecast is poor, a conditional decision may be needed.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
