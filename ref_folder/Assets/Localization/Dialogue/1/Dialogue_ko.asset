  m_SharedData: {fileID: 11400000, guid: e7034a1d06447604d9a19f4a8c5b13c1, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 534859776
    m_Localized: "\uC790, \uCCAB \uACC4\uC57D\uC774\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 572608512
    m_Localized: "\uC120\uBC15\uC758 \uC8FC\uC778\uC740 \uC0B0\uD0C0 \uB8E8\uC9C0\uC544.
      \uC120\uBC15 \uBCF4\uD5D8\uC744 \uC2E0\uCCAD\uD558\uB7EC \uC654\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 576802822
    m_Localized: "\uB3C4\uCC29\uD56D\uC740 \uC138\uD22C\uBC1C."
    m_Metadata:
      m_Items: []
  - m_Id: 384724499517440
    m_Localized: "\uAC15\uC744 \uB530\uB77C \uD558\uB8E8\uBA74 \uB2FF\uB294 \uD56D\uB85C\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 384798810001408
    m_Localized: "\uBCF5\uC7A1\uD55C \uAC74 \uC5C6\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 385031384158208
    m_Localized: "\uB0B4\uAC00 \uBBF8\uB9AC \uD6D1\uC5B4\uB454 \uACC4\uC57D\uC774\uC9C0\uB9CC,
      \uB124\uAC00 \uC9C1\uC811 \uD574\uBD10."
    m_Metadata:
      m_Items: []
  - m_Id: 385079849340928
    m_Localized: "\uC624\uB978\uCABD\uC744 \uBD10."
    m_Metadata:
      m_Items: []
  - m_Id: 385133469323264
    m_Localized: "\uC704\uB294 \uC808\uB300 \uAC70\uC808 \uC870\uAC74\uC774\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 385136770240512
    m_Localized: "\uD558\uB098\uB77C\uB3C4 \uB9DE\uC73C\uBA74 \uCCB4\uD06C\uD558\uACE0
      \uAC70\uC808\uD574."
    m_Metadata:
      m_Items: []
  - m_Id: 385140012437504
    m_Localized: "\uC544\uB798\uB294 \uAC70\uC808 \uACE0\uB824 \uC870\uAC74."
    m_Metadata:
      m_Items: []
  - m_Id: 385081480925184
    m_Localized: "\uD574\uB2F9\uD55C\uB2E4\uACE0 \uBC14\uB85C \uAC70\uC808\uD558\uB294
      \uAC74 \uC544\uB2C8\uC9C0\uB9CC, \uC5B4\uCA0C\uB4E0 \uC704\uD5D8 \uC694\uC18C\uB77C\uB294
      \uAC78 \uBA85\uC2EC\uD574. \uAC70\uC808\uC758 \uADFC\uAC70\uAC00 \uB420 \uC21C
      \uC788\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 385083108315136
    m_Localized: "\uB450 \uAE30\uC900\uC744 \uBA3C\uC800 \uD655\uC778\uD558\uACE0,
      \uD574\uB2F9\uC774 \uB418\uB294\uC9C0 \uBCF4\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 385121012240384
    m_Localized: "\uADF8\uB2E4\uC74C \uC2B9\uC778\uD560\uC9C0, \uAC70\uC808\uD560\uC9C0
      \uC815\uD558\uBA74 \uB3FC."
    m_Metadata:
      m_Items: []
  - m_Id: 385123281358848
    m_Localized: "\uC774\uBC88\uC5D0\uB294 \uCCAD\uC57D\uC11C\uC640 \uB4F1\uB85D\uC99D\uB9CC
      \uBCF4\uBA74 \uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 385125525311488
    m_Localized: "\uC120\uBC15\uBA85\uACFC \uC120\uC8FC\uBA85\uC5D0 \uC774\uC0C1\uC774
      \uC5C6\uB294 \uC9C0 \uD655\uC778\uD574. \uC774\uAC74 \uC911\uC694\uD55C \uBB38\uC81C\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 385127530188800
    m_Localized: "\uBCF4\uD5D8\uC5D0\uC11C \uAC00\uC7A5 \uC911\uC694\uD55C \uAC74
      \uC2E0\uC6A9\uC774\uB2E4. \uC774\uB7F0 \uC0AC\uC18C\uD55C \uC815\uBCF4\uBD80\uD130
      \uC5B4\uAE0B\uB09C\uB2E4\uBA74 \uC808\uB300 \uAC70\uC808 \uC0AC\uC720\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 385129547649024
    m_Localized: "\uB4F1\uB85D\uC99D\uC758 \uC720\uD6A8 \uAE30\uD55C\uB3C4 \uAF2D
      \uBCF4\uACE0. \uAE30\uD55C\uC774 \uC9C0\uB09C \uC120\uBC15\uC774\uBA74 \uBCF4\uD5D8\uC740
      \uBB3C\uB860 \uCD9C\uD56D \uC790\uCCB4\uB3C4 \uBD88\uAC00\uC57C."
    m_Metadata:
      m_Items: []
  - m_Id: 385131548332032
    m_Localized: "\uC774\uC0C1\uC774 \uC5C6\uB294 \uAE68\uB057\uD55C \uACC4\uC57D\uC774\uB77C
      \uD310\uB2E8\uB418\uBA74, \uC2B9\uC778\uC744 \uB204\uB974\uC790."
    m_Metadata:
      m_Items: []
  - m_Id: 551182567297024
    m_Localized: "\uB108\uAC00 \uCCB4\uACB0\uD55C \uBCF4\uD5D8\uB8CC\uC5D0 \uBE44\uB840\uD574\uC11C
      \uC815\uC0B0\uC744 \uBC1B\uAC8C \uB420\uAC70\uC57C. \uBE44\uC728\uC740 \uC2E4\uC801\uCE58\uC5D0
      \uBE44\uB840\uD574."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
