  m_text: "\uC0AC\uC2A4\uCF70\uCE58\uB294 \uB809\uC138\uD2B8 \uC124\uC6D0 \uB108\uBA38\uC758
    \uB3D9\uD1A0 \uD3C9\uC6D0\uC5D0 \uC11C\uC2DD\uD558\uB294 \uB9C8\uBB3C\uC774\uB2E4.
    \uAC1C\uCCB4 \uC218\uB294 \uB9CE\uC9C0 \uC54A\uC73C\uB098, \uB4DC\uBB3C\uAC8C
    1\uAC1C\uCCB4\uAC00 \uC0B0\uB9E5\uC744 \uB118\uC5B4 \uB809\uC11C\uD2B8\uC5D0\uC11C
