  m_text: "\uB9C8\uC744\uC5D0\uC11C \uB809\uC138\uD2B8 \uCD08\uC785\uAE4C\uC9C0\uB294
    \uD558\uB8FB\uAE38 \uC548\uC5D0 \uB2FF\uB294\uB2E4. \uCD08\uC785 \uAD6C\uAC04\uC740
    \uACBD\uC0AC\uAC00 \uC644\uB9CC\uD558\uACE0 \uD45C\uC9C0\uC11D\uC774 \uB0A8\uC544
    \uC788\uC5B4 \uC774\uB3D9 \uB09C\uB3C4\uB294 \uB0AE\uC740 \uD3B8\uC5D0 \uC18D\uD55C\uB2E4.
