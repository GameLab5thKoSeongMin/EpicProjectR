  m_text: "\uD574\uBB34 \uC18D\uC5D0\uC11C \uB5A0\uC624\uB974\uB294 \uBC18\uD22C\uBA85
    \uD574\uD30C\uB9AC\uB958 \uB9C8\uBB3C. \uD314\uC774\uB098 \uB2E4\uB9AC\uAC00
