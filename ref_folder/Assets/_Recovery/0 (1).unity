  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC138\uBC14\uB78C \uACE0\uAC1C\uB294 \uC218\uB3C4 \uC138\uB974\uBBF8\uC628\uACFC
    \uBD81\uB3D9 \uC678\uACFD\uC744 \uC787\uB294 \uAC00\uC7A5 \uC624\uB798\uB41C
    \uC0B0\uC545 \uAD00\uBB38\uC774\uB2E4. \uBD81\uB3D9\uBD80 \uC9C0\uC5ED\uC740
    \uC0B0\uB9E5 \uC9C0\uB300\uC778 \uD0D3\uC5D0 \uB300\uCCB4\uB85C \uB300\uADDC\uBAA8
    \uD1B5\uD589\uC774 \uC5B4\uB835\uC9C0\uB9CC, \uC138\uBC14\uB78C \uACE0\uAC1C\uB9CC\uC740
    \uC218\uB808\uC640 \uC18C\uADDC\uBAA8 \uD589\uB82C\uC774 \uC9C0\uB098\uAC08 \uC218
    \uC788\uB294 \uB0AE\uC740 \uC548\uBD80\uB97C \uC774\uB8EC\uB2E4.\n\uC774 \uACE0\uAC1C\uC5D0\uB294
    \uC138 \uBC29\uD5A5\uC758 \uBC14\uB78C\uC774 \uBD80\uB52A\uD78C\uB2E4.\n\uB0A8\uCABD\uC5D0\uC11C\uB294
    \uC218\uB3C4\uAD8C\uC758 \uB530\uB73B\uD558\uACE0 \uC2B5\uD55C \uBC14\uB78C\uC774
    \uC62C\uB77C\uC624\uACE0, \uBD81\uCABD\uC5D0\uC11C\uB294 \uC124\uC6D0 \uCABD\uC758
    \uCC28\uAC00\uC6B4 \uBC14\uB78C\uC774 \uB0B4\uB824\uC628\uB2E4. \uB3D9\uCABD\uC5D0\uC11C\uB294
    \uAD11\uC0B0\uC744 \uAC70\uCE5C \uBA3C\uC9C0 \uC11E\uC778 \uBC14\uB78C\uC774
    \uBAB0\uB824\uC628\uB2E4. \uC774 \uC138 \uBC14\uB78C\uC774 \uACE0\uAC1C \uC704\uC5D0\uC11C
    \uC5C9\uD0A4\uAE30 \uB54C\uBB38\uC5D0, \uB0A0\uC528\uAC00 \uD55C\uB098\uC808
    \uC548\uC5D0\uB3C4 \uBA87 \uBC88\uC529 \uB4A4\uC9D1\uD78C\uB2E4."
