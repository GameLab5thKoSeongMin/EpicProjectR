  m_GameObject: {fileID: 82171107}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC138\uBC14\uB78C \uACE0\uAC1C \uB108\uBA38, \uBD81\uB3D9 \uC678\uACFD\uC758
    \uC554\uB989 \uC9C0\uB300\uC5D0 \uC11C\uC2DD\uD558\uB294 \uC911\uD615 \uC6A9\uC885.
    \uBD81\uB3D9 \uC124\uC6D0\uC758 \uD55C\uAE30\uC5D0 \uBC00\uB824\uB09C \uC18C\uC218
    \uAC1C\uCCB4\uAC00 \uB4DC\uBB3C\uAC8C \uACE0\uAC1C\uB97C \uB118\uC5B4\uC628\uB2E4.\n\uD1F4\uD654\uD55C
    \uB0A0\uAC1C \uD0D3\uC5D0 \uBE44\uD589\uC740 \uBD88\uAC00\uB2A5\uD558\uC9C0\uB9CC,
    \uAD75\uC740 \uB124 \uB2E4\uB9AC\uC640 \uC554\uBC18\uC744 \uC6C0\uCF1C\uC950\uB294
    \uB2E8\uB2E8\uD55C \uBC1C\uD1B1\uC744 \uC9C0\uB154\uB2E4. \uB4F1\uC5D0\uB294
    \uBC14\uB78C\uC5D0 \uAE4E\uC778 \uB3CC\uAE30 \uAC19\uC740 \uBE44\uB298\uC774
    \uC19F\uC544 \uC788\uC73C\uBA70, \uAC15\uD48D\uC774 \uBD88\uBA74 \uADF8 \uD2C8\uC73C\uB85C
    \uB0AE\uC740 \uC6B8\uB9BC\uC774 \uC0C8\uC5B4 \uB098\uC628\uB2E4.\n\uC138\uBC14\uB78C
    \uACE0\uAC1C\uC758 \uB09C\uB958\uAC00 \uB4F1\uBE44\uB298\uC744 \uD6D1\uACE0 \uC9C0\uB098\uAC08
    \uB54C, \uADF8 \uC6B8\uB9BC\uC740 \uC9D0\uC2B9\uC758 \uD3EC\uD6A8\uCC98\uB7FC
    \uC0B0\uB9E5 \uC804\uCCB4\uC5D0 \uD37C\uC9C4\uB2E4. \uC774 \uB54C\uBB38\uC5D0
    \uBAA8\uD5D8\uAC00\uB4E4\uC740 \uC774 \uB4DC\uB808\uC774\uD06C\uB97C \u2018\uC2A4\uD1B0\uBC31\u2019\uC774\uB77C
    \uBD80\uB978\uB2E4.\n\uC218\uB3C4 \uC138\uB974\uBBF8\uC628\uACFC \uBD81\uB3D9
    \uC678\uACFD\uC744 \uC787\uB294 \uACBD\uACC4\uC9C0\uB300\uC5D0 \uC6A9\uC885\uC774
    \uCD9C\uD604\uD55C\uB2E4\uB294 \uC0AC\uC2E4\uC740 \uADF8 \uC790\uCCB4\uB85C \uC911\uB300\uD55C
    \uC704\uD611\uC774\uB2E4. \uCD9C\uBAB0\uC774 \uD655\uC778\uB420 \uACBD\uC6B0,
    \uC655\uAD6D\uC740 \uC219\uB828\uB41C \uBAA8\uD5D8\uAC00 \uD30C\uD2F0\uB97C \uD30C\uACAC\uD574
    \uC989\uC2DC \uD1A0\uBC8C\uC5D0 \uB098\uC120\uB2E4.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 96521caddb46f0642ab48b97de9841ea, type: 2}
