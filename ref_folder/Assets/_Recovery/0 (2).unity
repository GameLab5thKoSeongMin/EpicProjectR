  m_text: "\uC218\uB3C4 \uC138\uB974\uBBF8\uC628\uC758 \uC704\uC131 \uB3C4\uC2DC
    \uB77C\uC2A4\uB374 \uC678\uACFD \uAD6C\uC5ED. \uB77C\uC2A4\uB374\uC740 \uC218\uB3C4\uAD8C
    \uC774\uC8FC\uBBFC\uC744 \uBC1B\uC544\uB4E4\uC774\uBA70 \uBE60\uB974\uAC8C \uB3C4\uC2DC\uD654\uB418\uC5C8\uC9C0\uB9CC,
    \uADF8 \uBCC0\uD654\uB294 \uC678\uACFD\uAE4C\uC9C0 \uB2FF\uC9C0 \uBABB\uD588\uB2E4.
    \uACF5\uC0AC\uAC00 \uC911\uB2E8\uB41C \uC791\uC5C5\uC7A5, \uC369\uC740 \uC790\uC7AC,
    \uD3D0\uC218 \uBC30\uC218\uB85C\uAC00 \uACF3\uACF3\uC5D0 \uBC29\uCE58\uB418\uC5B4
    \uC788\uC73C\uBA70, \uC815\uBE44\uB418\uC9C0 \uC54A\uC740 \uB3C4\uB85C\uB294
    \uACC4\uC808\uACFC \uAD00\uACC4\uC5C6\uC774 \uB048\uC801\uD55C \uC9C4\uD759 \uC9C0\uB300\uB85C
    \uBCC0\uD574 \uC788\uB2E4. \uACBD\uBE44 \uC778\uB825\uB3C4 \uBD80\uC871\uD574
    \uC57D\uD0C8 \uC9D1\uB2E8\uC774 \uC790\uC8FC \uCD9C\uBAB0\uD558\uBA70, \uD589\uC778\uC744
    \uAE30\uC2B5\uD558\uAC70\uB098 \uB3C4\uC2DC \uB0B4\uBD80 \uC8FC\uAC70\uC9C0\uAE4C\uC9C0
    \uCE68\uC785\uD558\uB294 \uC0AC\uB840\uAC00 \uBCF4\uACE0\uB418\uACE0 \uC788\uB2E4."
  m_isRightToLeft: 0
