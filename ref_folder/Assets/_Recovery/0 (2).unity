      m_Calls: []
  m_text: "\uC120\uCCB4 \uC606\uBA74, \uBC27\uC904 \uB9E4\uB4ED, \uC816\uC740 \uAC11\uD310
    \uD2C8\uC5D0 \uBD99\uC5B4 \uC790\uB77C\uB294 \uD574\uC591\uC131 \uAD70\uCCB4
    \uB9C8\uBB3C\uC774\uB2E4. \uBA40\uB9AC\uC11C \uBCF4\uBA74 \uAC80\uD478\uB978
    \uBBF8\uC5ED \uC870\uAC01\uC774\uB098 \uC18C\uAE08\uBB3C\uC5D0 \uC816\uC740 \uCC9C\uCC98\uB7FC
    \uBCF4\uC778\uB2E4. \uC0AC\uB78C\uC758 \uBC1C\uC18C\uB9AC\uC640 \uCCB4\uC628\uC744
    \uAC10\uC9C0\uD558\uBA74 \uC587\uC740 \uC12C\uC720\uB9C9\uC744 \uBED7\uC5B4 \uBC1C\uBAA9,
    \uBD80\uCE20 \uB048, \uC7A5\uBE44 \uACE0\uB9AC\uB97C \uAC10\uB294\uB2E4. \uC0B4\uC0C1\uB825\uC740
    \uB0AE\uC9C0\uB9CC \uC816\uC740 \uAC11\uD310 \uC704\uC5D0\uC11C\uB294 \uCE58\uBA85\uC801\uC778
    \uC0AC\uACE0 \uC6D0\uC778\uC774 \uB41C\uB2E4. \uD2B9\uD788 \uB3CC\uD48D\uC774\uB098
    \uB108\uC6B8\uC774 \uC788\uB294 \uB0A0\uC5D0\uB294 \uB2E8\uC21C\uD55C \uB118\uC5B4\uC9D0\uC774
    \uC120\uC678 \uCD94\uB77D\uC73C\uB85C \uC774\uC5B4\uC9C8 \uC218 \uC788\uB2E4."
